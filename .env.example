# Copy to .env and fill in your staging credentials (never commit .env)

# Agent accounts (JMeter alternates between agent 1 and agent 2)
AGENT_EMAIL=agent@example.com
AGENT_PASSWORD=your-password-here
AGENT2_EMAIL=agent2@example.com
AGENT2_PASSWORD=your-password-here

# Widget / site (from your chat widget install)
WIDGET_PUBLIC_KEY=ws_your_widget_public_key
WIDGET_SITE_ID=your_site_id

# Optional overrides
CRM_API_HOST=api.crm.example.com
VISITOR_API_HOST=api.chat.example.com
VISITOR_ORIGIN=https://your-customer-site.example.com
