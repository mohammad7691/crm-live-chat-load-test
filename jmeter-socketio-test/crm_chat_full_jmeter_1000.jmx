          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">def t = ctx.getThreadNum() + 1
if (t % 2 == 0) {
  vars.put('agent_email', vars.get('agent2_email'))
  vars.put('agent_password', vars.get('agent2_password'))
} else {
  vars.put('agent_email', vars.get('agent_email'))
  vars.put('agent_password', vars.get('agent_password'))
}</stringProp>
