          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">def ws = vars.get(&apos;event_session_id&apos;)
def list = vars.get(&apos;list_session_id&apos;)
def sid = null
if (ws &amp;&amp; ws != &apos;NO_EVENT_SESSION&apos;) sid = ws
else if (list &amp;&amp; list != &apos;NO_LIST_SESSION&apos;) sid = list
vars.put(&apos;accept_session_id&apos;, sid ?: &apos;NO_SESSION&apos;)</stringProp>
        </JSR223PreProcessor>
