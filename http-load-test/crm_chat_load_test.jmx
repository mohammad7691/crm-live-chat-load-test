          <hashTree />
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Select Session For Reply" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename" />
            <stringProp name="parameters" />
            <stringProp name="script">import groovy.json.JsonSlurper

def text = prev.getResponseDataAsString()
def siteId = vars.get('widget_site_id')
if (!text?.trim()) {
    vars.put('selected_session_id', '')
    vars.put('selected_visitor_name', '')
    vars.put('selected_session_assigned', 'false')
    return
}
def data = new JsonSlurper().parseText(text)
def sessions = (data.sessions ?: []).findAll { it?.id }
def matchesSite = { s -&gt;
    String.valueOf(s.siteId ?: s.site?.id ?: '') == String.valueOf(siteId)
}
def unassigned = sessions.findAll { it.status == 'OPEN' &amp;&amp; !it.assignedToId &amp;&amp; matchesSite(it) }
def pool = unassigned ?: sessions.findAll { it.status == 'OPEN' &amp;&amp; matchesSite(it) }
if (pool.isEmpty()) {
    vars.put('selected_session_id', '')
    vars.put('selected_visitor_name', '')
    vars.put('selected_session_assigned', 'false')
    return
}
def chosen = pool[(Math.abs(ctx.getThreadNum()) + vars.getIteration()) % pool.size()]
vars.put('selected_session_id', String.valueOf(chosen.id))
vars.put('selected_visitor_name', String.valueOf(chosen.visitorName ?: 'visitor'))
vars.put('selected_session_assigned', chosen.assignedToId ? 'true' : 'false')</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
          </JSR223PostProcessor>
          <hashTree />
        </hashTree>
