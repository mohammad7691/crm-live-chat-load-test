              <stringProp name="HTTPSampler.path">/api/chat/sessions/${selected_session_id}/accept</stringProp>
              <stringProp name="HTTPSampler.method">POST</stringProp>
              <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
              <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
            </HTTPSamplerProxy>
            <hashTree>
              <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Treat Accept Conflict As Success" enabled="true">
                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="filename" />
                <stringProp name="parameters" />
                <stringProp name="script">def code = prev.getResponseCode()
if (code == '201' || code == '409') {
    prev.setSuccessful(true)
    prev.setResponseMessageOK(true)
}</stringProp>
                <stringProp name="scriptLanguage">groovy</stringProp>
              </JSR223PostProcessor>
              <hashTree />
              <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="Accept Chat Assertion" enabled="true">
                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="filename" />
                <stringProp name="parameters" />
                <stringProp name="script">def code = prev.getResponseCode()
def body = prev.getResponseDataAsString() ?: ''
if (code == '201' &amp;&amp; body.contains('assignedToId')) return
if (code == '409') return
AssertionResult.setFailureMessage('Unexpected accept response: ' + code + ' ' + body)
AssertionResult.setFailure(true)</stringProp>
                <stringProp name="scriptLanguage">groovy</stringProp>
              </JSR223Assertion>
              <hashTree />
            </hashTree>
