<?xml version='1.0' encoding='UTF-8'?>
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3">
  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="CRM Chat Load Test" enabled="true">
      <stringProp name="TestPlan.comments">End-to-end staging load test: visitor public chat messages, agent accept, and agent replies.</stringProp>
      <boolProp name="TestPlan.functional_mode">false</boolProp>
      <boolProp name="TestPlan.tearDown_on_shutdown">true</boolProp>
      <boolProp name="TestPlan.serialize_threadgroups">false</boolProp>
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments" guiclass="ArgumentsPanel" testclass="Arguments" testname="User Defined Variables" enabled="true">
        <collectionProp name="Arguments.arguments">
          <elementProp name="visitor_threads" elementType="Argument">
            <stringProp name="Argument.name">visitor_threads</stringProp>
            <stringProp name="Argument.value">50</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="agent_threads" elementType="Argument">
            <stringProp name="Argument.name">agent_threads</stringProp>
            <stringProp name="Argument.value">50</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="ramp_up" elementType="Argument">
            <stringProp name="Argument.name">ramp_up</stringProp>
            <stringProp name="Argument.value">60</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="loops" elementType="Argument">
            <stringProp name="Argument.name">loops</stringProp>
            <stringProp name="Argument.value">10</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="visitor_base" elementType="Argument">
            <stringProp name="Argument.name">visitor_base</stringProp>
            <stringProp name="Argument.value">https://nst.staging.rev9solutions.com</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="crm_app_base" elementType="Argument">
            <stringProp name="Argument.name">crm_app_base</stringProp>
            <stringProp name="Argument.value">https://app.crm.swagprinthub.com</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="crm_api_base" elementType="Argument">
            <stringProp name="Argument.name">crm_api_base</stringProp>
            <stringProp name="Argument.value">https://api.crm.swagprinthub.com</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="agent_email" elementType="Argument">
            <stringProp name="Argument.name">agent_email</stringProp>
            <stringProp name="Argument.value">${__P(agent_email,agent@example.com)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="agent_password" elementType="Argument">
            <stringProp name="Argument.name">agent_password</stringProp>
            <stringProp name="Argument.value">${__P(agent_password,)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="zendesk_key" elementType="Argument">
            <stringProp name="Argument.name">zendesk_key</stringProp>
            <stringProp name="Argument.value">e38c293d-dbac-4dcf-9097-fb2d9c0912e3</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="widget_site_id" elementType="Argument">
            <stringProp name="Argument.name">widget_site_id</stringProp>
            <stringProp name="Argument.value">cmrd7thsz0000ncqggnafo1ri</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="widget_public_key" elementType="Argument">
            <stringProp name="Argument.name">widget_public_key</stringProp>
            <stringProp name="Argument.value">${__P(widget_public_key,ws_your_widget_key)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
        </collectionProp>
      </elementProp>
      <stringProp name="TestPlan.user_define_classpath" />
    </TestPlan>
    <hashTree>
      <ConfigTestElement guiclass="HttpDefaultsGui" testclass="ConfigTestElement" testname="HTTP Defaults" enabled="true">
        <stringProp name="HTTPSampler.protocol">https</stringProp>
        <stringProp name="HTTPSampler.contentEncoding">UTF-8</stringProp>
      </ConfigTestElement>
      <hashTree />
      <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="Common Headers" enabled="true">
        <collectionProp name="HeaderManager.headers">
          <elementProp name="" elementType="Header">
            <stringProp name="Header.name">Accept</stringProp>
